{
  "github_token": {
    "description": "GitHub Personal Access Token",
    "type": "string",
    "default": "",
    "hint": "用于访问私有仓库和组织项目，格式 ghp_xxxxxxxxxxxx，需具有对应仓库/组织的 repo、read:org、user 权限"
  },
  "poll_interval": {
    "description": "轮询间隔（秒）",
    "type": "int",
    "default": 1800,
    "hint": "每隔多少秒检查一次动态，默认 1800 秒（30 分钟），建议不低于 600 秒"
  },
  "max_entries": {
    "description": "每次最多推送条目数",
    "type": "int",
    "default": 5,
    "hint": "单次推送每个订阅项最多显示多少条新动态，设为 0 则不限制"
  },
  "timezone": {
    "description": "时区",
    "type": "string",
    "default": "Asia/Shanghai",
    "hint": "用于将 GitHub 动态的时间转换为本地时间，例如 Asia/Shanghai"
  },
  "username_qq": {
    "type": "list",
    "description": "GitHub 用户名与 QQ 号映射（字符串列表格式）",
    "items": {
      "type": "string",
      "pattern": "^[^:]+:.+$",
      "description": "格式：用户名:QQ号，例如 CecilyGao:1527519027"
    },
    "default": [],
    "hint": "例：[\"CecilyGao:1527519027\", \"octocat:123456789\"]"
  },
  "at_enable": {
    "type": "bool",
    "description": "是否在推送消息中 @ 对应的 QQ 号",
    "default": false,
    "hint": "在推送消息中 @ 对应的 QQ 号，需配合 username_qq 映射使用"
  },
  "whitelist": {
    "description": "白名单用户",
    "type": "list",
    "default": [],
    "hint": "只有白名单用户或管理员可以使用订阅管理指令。留空则所有用户均可使用"
  },
  "subscriptions": {
    "description": "GitHub 订阅配置列表（可动态添加）",
    "hint": "通过命令 gh subscribe 动态添加/删除，也可手动编辑。支持群聊独立订阅。",
    "type": "template_list",
    "default": [],
    "templates": {
      "user_subscription": {
        "name": "用户订阅",
        "description": "订阅目标 GitHub 用户的动态",
        "items": {
          "group_id": {
            "type": "string",
            "description": "群号",
            "hint": "群聊时填群号，私聊留空",
            "default": ""
          },
          "user_id": {
            "type": "string",
            "description": "GitHub 用户名",
            "hint": "例如：CecilyGao",
            "default": ""
          }
        }
      },
      "repo_subscription": {
        "name": "仓库订阅",
        "description": "订阅目标 GitHub 仓库的动态",
        "items": {
          "group_id": {
            "type": "string",
            "description": "群号",
            "hint": "群聊时填群号，私聊留空",
            "default": ""
          },
          "repo_id": {
            "type": "string",
            "description": "仓库名",
            "hint": "格式：owner/repo 例如：CecilyGao/astrbot_plugin_github_dynamics",
            "default": ""
          },
          "issues_enabled": {
            "type": "bool",
            "description": "监听 Issues",
            "default": false
          },
          "commits_enabled": {
            "type": "bool",
            "description": "监听 Commits",
            "default": false
          },
          "releases_enabled": {
            "type": "bool",
            "description": "监听 Releases",
            "default": false
          }
        }
      },
      "project_subscription": {
        "name": "组织项目订阅",
        "description": "订阅 GitHub 组织下的 Projects V2 项目动态",
        "items": {
          "group_id": {
            "type": "string",
            "description": "群号",
            "hint": "群聊时填群号，私聊留空",
            "default": ""
          },
          "organization_id": {
            "type": "string",
            "description": "组织名",
            "hint": "例如：facebook",
            "default": ""
          },
          "project_id": {
            "type": "string",
            "description": "项目编号（数字），可在url中查看",
            "hint": "例如：123",
            "default": ""
          }
        }
      }
    }
  }
}